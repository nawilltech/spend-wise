DATABASE_URL=postgresql+asyncpg://spendwise:password@localhost:5432/spendwise
REDIS_URL=redis://localhost:6379/0

SECRET_KEY=change-this-to-a-random-256-bit-key
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key

OPEN_EXCHANGE_RATES_APP_ID=your-oxr-app-id

# Comma-separated list (no spaces around commas)
