DATABASE_URL=postgresql+asyncpg://spendwise:password@localhost:5432/spendwise
REDIS_URL=redis://localhost:6379/0
API_BASE_URL=http://localhost:8000

SECRET_KEY=change-this-to-a-random-256-bit-key
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# SMTP (leave empty to log OTPs to console in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@spendwise.app

GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key

OPEN_EXCHANGE_RATES_APP_ID=your-oxr-app-id

# Comma-separated list (no spaces around commas)
ALLOWED_ORIGINS=http://localhost:8081,exp://localhost:8081,http://localhost:3000

ENVIRONMENT=development
DEBUG=true
